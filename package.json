    "build-create": "esbuild src/functions/create-order/app.js --bundle --platform=node --target=node24 --outfile=dist/create-order/app.js",
    "build-get": "esbuild src/functions/get-order/app.js --bundle --platform=node --target=node24 --outfile=dist/get-order/app.js",
    "build-reserve": "esbuild src/functions/reserve-inventory/app.js --bundle --platform=node --target=node24 --outfile=dist/reserve-inventory/app.js",
    "build-authorize": "esbuild src/functions/authorize-payment/app.js --bundle --platform=node --target=node24 --outfile=dist/authorize-payment/app.js",
