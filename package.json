    "build-fail": "esbuild src/functions/fail-order/app.js --bundle --platform=node --target=node24 --outfile=dist/fail-order/app.js",
    "zip-create": "zip -r dist/create-order/app.zip dist/create-order/app.js",
    "zip-get": "zip -r dist/get-order/app.zip dist/get-order/app.js",
    "zip-reserve": "zip -r dist/reserve-inventory/app.zip dist/reserve-inventory/app.js",
    "zip-authorize": "zip -r dist/authorize-payment/app.zip dist/authorize-payment/app.js",
    "zip-complete": "zip -r dist/complete-order/app.zip dist/complete-order/app.js",
    "zip-fail": "zip -r dist/fail-order/app.zip dist/fail-order/app.js",
    "build": "npm run build-create && npm run build-get && npm run build-reserve && npm run build-authorize && npm run build-complete && npm run build-fail",
